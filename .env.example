# Copier vers .env.test / .env.prod et remplir. Préfixe VITE_ requis.

VITE_PAYDUNYA_MASTER_KEY=
VITE_PAYDUNYA_TEST_PRIVATE_KEY=
VITE_PAYDUNYA_TEST_PUBLIC_KEY=
VITE_PAYDUNYA_TEST_TOKEN=
VITE_PAYDUNYA_LIVE_PRIVATE_KEY=
VITE_PAYDUNYA_LIVE_PUBLIC_KEY=
VITE_PAYDUNYA_LIVE_TOKEN=
VITE_PAYDUNYA_LIVE_MODE=false

# WhatsApp — demandes formation (QR + lien). Chiffres uniquement, indicatif pays sans + (ex. 221774621725).
VITE_WHATSAPP_FORMATION_PHONE=221784649530

# Page « Loggpatient » — lien dans le pied de page (nouvel onglet).
VITE_LOGGPATIENT_PAGE_URL=

# Réseaux sociaux — page contact (icônes affichées seulement si l’URL est renseignée).
VITE_CONTACT_YOUTUBE_URL=
VITE_CONTACT_FACEBOOK_URL=
VITE_CONTACT_TIKTOK_URL=
VITE_CONTACT_LINKEDIN_URL=
